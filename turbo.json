{
  "$schema": "https://v2-10-0.turborepo.dev/schema.json",
  "tasks": {
    "typecheck": {
      "outputs": []
    },
    "lint": {
      "cache": false,
      "outputs": []
    },
    "fmt": {
      "cache": false,
      "outputs": []
    },
    "fmt:check": {
      "cache": false,
      "dependsOn": ["typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["typecheck"],
      "outputs": []
    },
    "generate": {
      "outputs": []
    },
    "typecheck:app": {
      "outputs": []
    },
    "build": {
      "dependsOn": ["^typecheck", "typecheck"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "check": {
      "dependsOn": ["typecheck", "lint", "fmt"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
