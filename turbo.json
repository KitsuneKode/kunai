{
  "$schema": "https://v2-10-0.turborepo.dev/schema.json",
  "tasks": {
    "transit": {
      "dependsOn": ["^transit"]
    },
    "typecheck": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "lint": {
      "cache": false,
      "outputs": []
    },
    "fmt": {
      "cache": false,
      "outputs": []
    },
    "fmt:check": {
      "cache": false,
      "dependsOn": ["typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "test:unit": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "test:integration": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "generate": {
      "outputs": []
    },
    "typecheck:app": {
      "outputs": []
    },
    "build": {
      "dependsOn": ["^typecheck", "typecheck"],
      "outputs": [
        "dist/kunai.js",
        "dist/kunai.mjs",
        "dist/npm/**",
        "dist/assets/**",
        "dist/build-meta.json",
        ".next/**",
        "!.next/cache/**"
      ],
      "env": ["KUNAI_BUILD_ANALYZE"]
    },
    "build:binary:host": {
      "dependsOn": ["^typecheck", "typecheck"],
      "outputs": ["dist/bin/kunai-*", "dist/bin/SHA256SUMS", "dist/bin/*.meta.json"],
      "env": ["KUNAI_BUILD_ANALYZE"]
    },
    "build:binaries": {
      "dependsOn": ["^typecheck", "typecheck"],
      "outputs": ["dist/bin/**"],
      "env": ["KUNAI_BUILD_ANALYZE"]
    },
    "check": {
      "dependsOn": ["typecheck", "lint", "fmt"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
