{
  "$schema": "https://v2-9-16.turborepo.dev/schema.json",
  "tasks": {
    "typecheck": {
      "outputs": []
    },
    "lint": {
      "cache": false,
      "outputs": []
    },
    "fmt": {
      "cache": false,
      "outputs": []
    },
    "fmt:check": {
      "cache": false,
      "dependsOn": ["typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["typecheck"],
      "outputs": []
    },
    "build": {
      "dependsOn": ["typecheck"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "check": {
      "dependsOn": ["typecheck", "lint", "fmt"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
