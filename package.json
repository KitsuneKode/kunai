{
  "name": "kitsune-snipe",
  "version": "0.1.0",
  "description": "Terminal-first CLI streaming engine that intercepts playable streams with Playwright and launches mpv.",
  "keywords": [
    "anime",
    "bun",
    "cli",
    "mpv",
    "playwright",
    "streaming",
    "terminal"
  ],
  "homepage": "https://github.com/kitsunekode/kitsunesnipe#readme",
  "bugs": {
    "url": "https://github.com/kitsunekode/kitsunesnipe/issues"
  },
  "license": "MIT",
  "author": "kitsunekode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kitsunekode/kitsunesnipe.git"
  },
  "bin": {
    "kitsune-snipe": "./dist/kitsune-snipe.js",
    "kitsunesnipe": "./dist/kitsune-snipe.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "module": "./dist/kitsune-snipe.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run index.ts",
    "start": "bun run index.ts",
    "test": "bun test",
    "typecheck": "bun tsc --noEmit",
    "lint": "./node_modules/.bin/oxlint .",
    "format": "./node_modules/.bin/oxfmt --check .",
    "format:write": "./node_modules/.bin/oxfmt --write .",
    "check": "bun run typecheck && bun run lint && bun run format",
    "clean": "rm -rf dist",
    "build": "bun run clean && bun build index.ts --target bun --packages external --outfile dist/kitsune-snipe.js && chmod 755 dist/kitsune-snipe.js",
    "build:prod": "bun run check && bun run build",
    "pkg:check": "bun run build && npm pack --dry-run --ignore-scripts",
    "release:dry-run": "bun run build:prod && bun run pkg:check",
    "link:global": "bun link",
    "unlink:global": "bun unlink",
    "relink:global": "bun run unlink:global && bun run link:global",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@kitsunekode/run-cli": "^0.1.0",
    "@types/react": "^19.2.14",
    "ink": "^7.0.1",
    "ink-text-input": "^6.0.0",
    "playwright": "^1.59.1",
    "react": "^19.2.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.3.9"
  }
}
