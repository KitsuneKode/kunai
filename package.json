{
  "name": "kunai",
  "private": true,
  "description": "Kunai monorepo workspace.",
  "workspaces": {
    "packages": [
      "apps/cli",
      "apps/docs",
      "apps/relay-server",
      "apps/telemetry-ingest",
      "packages/*"
    ],
    "catalog": {
      "typescript": "^7.0.2",
      "@types/bun": "1.3.14",
      "@types/node": "^26.1.1",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "zod": "^4.4.3"
    },
    "catalogs": {
      "cli": {
        "commander": "^15.0.0",
        "ink": "^7.1.1"
      },
      "lint": {
        "oxfmt": "^0.59.0",
        "oxlint": "^1.74.0"
      },
      "providers": {
        "@assemblyscript/loader": "^0.28.19",
        "@types/crypto-js": "^4.2.2",
        "crypto-js": "^4.2.0"
      },
      "repo": {
        "turbo": "^2.10.5"
      },
      "web": {
        "@base-ui/react": "^1.6.0",
        "@tabler/icons-react": "^3.45.0",
        "@tailwindcss/postcss": "^4.3.3",
        "@types/mdx": "^2.0.14",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "fumadocs-core": "^16.11.5",
        "fumadocs-mdx": "^15.2.0",
        "fumadocs-ui": "^16.11.5",
        "motion": "^12.42.2",
        "next": "^16.2.10",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.3",
        "tw-animate-css": "^1.4.0",
        "typescript": "5.9.3"
      }
    }
  },
  "scripts": {
    "dev": "bun apps/cli/src/main.ts",
    "bin": "scripts/bin.sh",
    "dev:relay": "bun run --cwd apps/relay-server dev",
    "relay:verify": "bun run --cwd apps/relay-server verify:deploy",
    "dev:docs": "bun run --cwd apps/docs dev",
    "start": "bun run --cwd apps/cli start",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "fmt": "turbo run fmt",
    "fmt:check": "turbo run fmt:check",
    "test": "turbo run test",
    "test:coverage": "bun run --cwd apps/cli test:coverage",
    "test:cli:file": "bun run --cwd apps/cli test:file",
    "test:installer:docker": "bun run --cwd apps/cli test:installer:docker",
    "test:installer:ci": "bun run --cwd apps/cli test:installer:ci",
    "test:live:allanime": "bun run --cwd apps/cli test:live:allanime",
    "test:live:discord": "bun run --cwd apps/cli test:live:discord",
    "test:live:miruro": "bun run --cwd apps/cli test:live:miruro",
    "test:live:matrix": "bun run --cwd apps/cli test:live:matrix",
    "test:live:youtube": "bun run --cwd apps/cli test:live:youtube",
    "test:live:providers": "bun run --cwd apps/cli test:live:providers",
    "test:live:rivestream": "bun run --cwd apps/cli test:live:rivestream",
    "test:live:relay-allanime": "bun run --cwd apps/cli test:live:relay-allanime",
    "test:live:videasy": "bun run --cwd apps/cli test:live:videasy",
    "test:live:videasy:suite": "bun run --cwd apps/cli test:live:videasy:suite",
    "test:live:vidking": "bun run --cwd apps/cli test:live:videasy",
    "ci": "turbo run typecheck lint fmt:check test --summarize",
    "ci:affected": "turbo run typecheck lint fmt:check test --affected --summarize",
    "build": "turbo run build build:binary:host --filter=@kitsunekode/kunai",
    "brand:social": "bun .design/brand/generate-social-cards.mjs",
    "build:binaries": "turbo run build:binaries --filter=@kitsunekode/kunai",
    "build:binary:host": "bun run --cwd apps/cli build:binary:host",
    "build:binary:host:test": "bun run --cwd apps/cli build:binary:host:test",
    "verify:binary:host": "bun run --cwd apps/cli verify:binary:host",
    "build:all": "turbo run build",
    "build:docs": "turbo run build --filter=@kunai/docs",
    "check": "turbo run check",
    "clean": "turbo run clean",
    "experiments:install": "bun install --cwd apps/experiments",
    "experiments:list": "bun run --cwd apps/experiments list",
    "pkg:check": "bun run --cwd apps/cli pkg:check",
    "verify:build-pipeline": "bun run scripts/verify-build-pipeline.ts",
    "verify:build-pipeline:pr": "bun run scripts/verify-build-pipeline.ts --pr",
    "verify:build-pipeline:all-targets": "bun run scripts/verify-build-pipeline.ts --all-targets",
    "release:dry-run": "bun run --cwd apps/cli release:dry-run",
    "changeset": "bunx changeset",
    "version:packages": "bunx changeset version && bun run scripts/sync-root-changelog.ts && bun run release:notes",
    "release:notes": "bun run scripts/generate-release-notes.ts",
    "release:notes:check": "bun run scripts/generate-release-notes.ts --check",
    "release": "bunx changeset publish",
    "guard": "bun run scripts/release-guard.ts",
    "link:global": "bun run --cwd apps/cli link:global",
    "unlink:global": "bun run --cwd apps/cli unlink:global",
    "relink:global": "bun run --cwd apps/cli relink:global",
    "prepare": "husky",
    "prototype:serve": "node .prototypes/_harness/server.js",
    "prototype:layout-fixtures": "bun run apps/cli/scripts/export-list-row-layout-fixtures.ts"
  },
  "dependencies": {
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "oxfmt": "catalog:lint",
    "oxlint": "catalog:lint",
    "turbo": "catalog:repo"
  },
  "overrides": {
    "@types/node": "catalog:",
    "fumadocs-core": "catalog:web",
    "fumadocs-ui": "catalog:web",
    "ws": "^8.21.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "oxlint",
      "oxfmt --write"
    ],
    "**/*.{json,md}": [
      "oxfmt --write"
    ],
    "apps/cli/package.json": [
      "bun run guard"
    ],
    "apps/cli/CHANGELOG.md": [
      "bun run guard"
    ],
    "CHANGELOG.md": [
      "bun run guard"
    ],
    ".changeset/*.md": [
      "bun run guard"
    ],
    ".release/*.{json,md}": [
      "bun run release:notes:check"
    ]
  },
  "engines": {
    "bun": ">=1.3.9"
  },
  "packageManager": "bun@1.3.14"
}
