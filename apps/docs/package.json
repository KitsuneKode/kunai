{
  "name": "@kunai/docs",
  "private": true,
  "description": "Fumadocs-powered documentation site for Kunai user and developer docs.",
  "type": "module",
  "scripts": {
    "generate": "bun run scripts/sync-code-metadata.ts && fumadocs-mdx",
    "dev": "bun run generate && next dev",
    "build": "bun run generate && NEXT_TELEMETRY_DISABLED=1 next build --webpack",
    "typecheck": "bun run generate && bun tsc --noEmit",
    "lint": "oxlint app lib test mdx-components.tsx next.config.mjs source.config.ts",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "test": "bun test test",
    "clean": "rm -rf .next dist .source"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.2.0",
    "@hugeicons/react": "^1.1.6",
    "@types/mdx": "^2.0.14",
    "framer-motion": "^12.40.0",
    "fumadocs-core": "^16.9.3",
    "fumadocs-mdx": "^15.0.11",
    "fumadocs-ui": "^16.9.3",
    "gsap": "^3.15.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bun": "1.3.14",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.3.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.3.9"
  }
}
