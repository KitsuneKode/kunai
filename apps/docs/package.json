{
  "name": "@kunai/docs",
  "private": true,
  "description": "Fumadocs-powered documentation site for Kunai user and developer docs.",
  "type": "module",
  "scripts": {
    "generate": "bun run scripts/sync-code-metadata.ts && fumadocs-mdx",
    "dev": "bun run generate && next dev",
    "build:app": "NEXT_TELEMETRY_DISABLED=1 next build",
    "build": "bun run build:app",
    "start": "next start",
    "typecheck:app": "bun tsc --noEmit",
    "typecheck": "bun run typecheck:app",
    "lint": "oxlint app components lib scripts test mdx-components.tsx next.config.mjs source.config.ts",
    "lighthouse:docs": "bun run scripts/lighthouse-docs.ts",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "test": "bun test test",
    "clean": "rm -rf .next dist .source"
  },
  "dependencies": {
    "@base-ui/react": "catalog:web",
    "@kunai/design": "workspace:*",
    "@tabler/icons-react": "catalog:web",
    "class-variance-authority": "catalog:web",
    "clsx": "catalog:web",
    "fumadocs-core": "catalog:web",
    "fumadocs-mdx": "catalog:web",
    "fumadocs-ui": "catalog:web",
    "motion": "catalog:web",
    "next": "catalog:web",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwind-merge": "catalog:web",
    "tw-animate-css": "catalog:web"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "catalog:web",
    "@types/bun": "catalog:",
    "@types/mdx": "catalog:web",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "shadcn": "^4.13.1",
    "tailwindcss": "catalog:web",
    "typescript": "catalog:web"
  },
  "engines": {
    "bun": ">=1.3.9"
  }
}
