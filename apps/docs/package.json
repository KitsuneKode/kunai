{
  "name": "@kunai/docs",
  "private": true,
  "description": "Fumadocs-powered documentation site for Kunai user and developer docs.",
  "type": "module",
  "scripts": {
    "generate": "bun run scripts/sync-code-metadata.ts && fumadocs-mdx",
    "dev": "bun run generate && next dev",
    "build": "bun run generate && NEXT_TELEMETRY_DISABLED=1 next build --webpack",
    "typecheck": "bun run generate && bun tsc --noEmit",
    "lint": "oxlint app lib test mdx-components.tsx next.config.mjs source.config.ts",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "test": "bun test test",
    "clean": "rm -rf .next dist .source"
  },
  "dependencies": {
    "@types/mdx": "^2.0.13",
    "fumadocs-core": "^16.9.3",
    "fumadocs-mdx": "^15.0.10",
    "fumadocs-ui": "^16.9.3",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bun": "1.3.14",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.65.0",
    "tailwindcss": "^4.3.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.3.9"
  }
}
