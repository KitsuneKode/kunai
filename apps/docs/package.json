{
  "name": "@kunai/docs",
  "private": true,
  "description": "Fumadocs-powered documentation site for Kunai user and developer docs.",
  "type": "module",
  "scripts": {
    "generate": "bun run scripts/sync-code-metadata.ts && fumadocs-mdx",
    "dev": "bun run generate && next dev",
    "build:app": "NEXT_TELEMETRY_DISABLED=1 next build",
    "build": "bun run build:app",
    "start": "next start",
    "typecheck:app": "bun tsc --noEmit",
    "typecheck": "bun run typecheck:app",
    "lint": "oxlint app components lib scripts test mdx-components.tsx next.config.mjs source.config.ts",
    "lighthouse:docs": "bun run scripts/lighthouse-docs.ts",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "test": "bun test test",
    "clean": "rm -rf .next dist .source"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@kunai/design": "workspace:*",
    "@tabler/icons-react": "^3.45.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "^16.11.5",
    "fumadocs-mdx": "^15.2.0",
    "fumadocs-ui": "^16.11.5",
    "geist": "^1.7.2",
    "motion": "^12.42.2",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/bun": "catalog:",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "shadcn": "^4.13.1",
    "tailwindcss": "^4.3.2",
    "typescript": "5.9.2"
  },
  "engines": {
    "bun": ">=1.3.9"
  }
}
