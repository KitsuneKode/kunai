{
  "name": "@kunai/docs",
  "private": true,
  "description": "Fumadocs-powered documentation site for Kunai user and developer docs.",
  "type": "module",
  "scripts": {
    "generate": "bun run scripts/sync-code-metadata.ts && fumadocs-mdx",
    "dev": "bun run generate && next dev",
    "build": "bun run generate && NEXT_TELEMETRY_DISABLED=1 next build --webpack",
    "typecheck": "bun run generate && bun tsc --noEmit",
    "lint": "oxlint app lib test mdx-components.tsx next.config.mjs source.config.ts",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "test": "bun test test",
    "clean": "rm -rf .next dist .source"
  },
  "dependencies": {
    "@kunai/design": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "catalog:web",
    "fumadocs-mdx": "catalog:web",
    "fumadocs-ui": "catalog:web",
    "lucide-react": "catalog:web",
    "motion": "^12.40.0",
    "next": "catalog:web",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "catalog:web",
    "@types/bun": "catalog:",
    "@types/mdx": "^2.0.14",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "oxfmt": "catalog:lint",
    "oxlint": "catalog:lint",
    "tailwindcss": "catalog:web"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.9"
  }
}
