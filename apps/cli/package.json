{
  "name": "@kitsunekode/kunai",
  "version": "0.2.5",
  "description": "Terminal-first media streaming CLI that resolves provider streams and launches mpv.",
  "keywords": [
    "anime",
    "bun",
    "cli",
    "discord-presence",
    "history",
    "intro-skip",
    "movies",
    "mpv",
    "series",
    "streaming",
    "terminal"
  ],
  "homepage": "https://github.com/KitsuneKode/kunai#readme",
  "bugs": {
    "url": "https://github.com/KitsuneKode/kunai/issues"
  },
  "license": "MIT",
  "author": "kitsunekode",
  "repository": {
    "type": "git",
    "url": "https://github.com/KitsuneKode/kunai"
  },
  "bin": {
    "kunai": "dist/kunai.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "module": "./dist/kunai.js",
  "exports": {
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "bun run src/main.ts",
    "profile:anime": "KUNAI_HEAP_PROFILE=1 KUNAI_HEAP_CAP_MB=2048 bun run src/main.ts -a --debug",
    "start": "bun run dist/kunai.js",
    "test": "bun test test/unit test/integration",
    "test:file": "bun test",
    "test:unit": "bun test test/unit",
    "test:integration": "bun test test/integration",
    "test:installer:docker": "bash test/docker/native-installer/run-local.sh",
    "test:installer:ci": "KUNAI_INSTALLER_DOCKER=1 bash test/docker/native-installer/run-local.sh",
    "test:live:allanime": "bun -e \"await import('./test/live/allanime-demonslayer.smoke.ts')\"",
    "test:live:discord": "bun -e \"await import('./test/live/discord-presence.smoke.ts')\"",
    "test:live:miruro": "bun -e \"await import('./test/live/miruro-demonslayer.smoke.ts')\"",
    "test:live:matrix": "bun -e \"await import('./test/live/provider-matrix.smoke.ts')\"",
    "test:live:providers": "bun run test:live:videasy && bun run test:live:rivestream && bun run test:live:allanime && bun run test:live:miruro",
    "test:live:rivestream": "bun -e \"await import('./test/live/rivestream-breakingbad.smoke.ts')\"",
    "test:live:relay-allanime": "bun -e \"await import('./test/live/relay-allanime.smoke.ts')\"",
    "test:live:videasy": "bun -e \"await import('./test/live/videasy-bloodhounds.smoke.ts')\"",
    "test:live:vidking": "bun run test:live:videasy",
    "test:vhs:setup": "vhs test/vhs/setup.tape",
    "test:vhs:offline": "vhs test/vhs/offline-library.tape",
    "test:vhs:palette": "vhs test/vhs/command-palette.tape",
    "test:vhs:all": "bun run test:vhs:setup && bun run test:vhs:offline && bun run test:vhs:palette",
    "typecheck": "bun tsc --noEmit",
    "lint": "oxlint .",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "check": "bun run typecheck && bun run lint && bun run fmt",
    "clean": "rm -rf dist",
    "build": "bun run scripts/build.ts",
    "build:watch": "bun --watch run scripts/build.ts",
    "build:analyze": "KUNAI_BUILD_ANALYZE=1 bun run scripts/build.ts",
    "build:binaries": "bun run scripts/build-binaries.ts",
    "build:prod": "bun run check && bun run build",
    "pkg:check": "npm pack --dry-run --ignore-scripts",
    "release:dry-run": "bun run build:prod && bun run pkg:check",
    "link:global": "bun link",
    "unlink:global": "bun unlink",
    "relink:global": "bun run unlink:global && bun run link:global",
    "prepack": "bun run build",
    "postinstall": "bun run scripts/postinstall.ts"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "ink": "^7.1.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@kunai/core": "workspace:*",
    "@kunai/design": "workspace:*",
    "@kunai/providers": "workspace:*",
    "@kunai/relay": "workspace:*",
    "@kunai/storage": "workspace:*",
    "@kunai/types": "workspace:*",
    "@types/bun": "1.3.14",
    "@types/react": "^19.2.17",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.3.9"
  }
}
