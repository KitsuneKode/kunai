{
  "name": "kunai",
  "version": "0.1.0-beta.0",
  "description": "Elite terminal-first streaming engine. Intercepts playable streams with Playwright and launches mpv.",
  "keywords": [
    "anime",
    "bun",
    "cli",
    "mpv",
    "playwright",
    "streaming",
    "terminal"
  ],
  "homepage": "https://github.com/kitsunekode/kunai#readme",
  "bugs": {
    "url": "https://github.com/kitsunekode/kunai/issues"
  },
  "license": "MIT",
  "author": "kitsunekode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kitsunekode/kunai.git"
  },
  "bin": {
    "kunai": "./dist/kunai.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "./dist/kunai.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/main.ts",
    "start": "bun run src/main.ts",
    "test": "bun test test/unit test/integration",
    "test:unit": "bun test test/unit",
    "test:integration": "bun test test/integration",
    "test:live:allanime": "bun run test/live/allanime-demonslayer.smoke.ts",
    "test:live:vidking": "bun run test/live/vidking-bloodhounds.smoke.ts",
    "test:vhs:browse": "vhs test/vhs/browse-shell.tape",
    "test:vhs:help": "vhs test/vhs/help-overlay.tape",
    "typecheck": "bun tsc --noEmit",
    "lint": "oxlint .",
    "fmt": "oxfmt --write .",
    "check": "bun run typecheck && bun run lint && bun run fmt",
    "clean": "rm -rf dist",
    "build": "bun run clean && bun build src/main.ts --target bun --packages external --outfile dist/kunai.js && chmod 755 dist/kunai.js",
    "build:prod": "bun run check && bun run build",
    "pkg:check": "bun run build && npm pack --dry-run --ignore-scripts",
    "release:dry-run": "bun run build:prod && bun run pkg:check",
    "link:global": "bun link",
    "unlink:global": "bun unlink",
    "relink:global": "bun run unlink:global && bun run link:global",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@assemblyscript/loader": "^0.28.16",
    "@clack/prompts": "^1.2.0",
    "@kitsunekode/run-cli": "^0.1.0",
    "@types/crypto-js": "^4.2.2",
    "@types/jquery": "^4.0.0",
    "@types/jsdom": "^28.0.1",
    "@types/react": "^19.2.14",
    "cheerio": "^1.2.0",
    "crypto-js": "^4.2.0",
    "hashids": "^2.3.0",
    "ink": "^7.0.1",
    "ink-text-input": "^6.0.0",
    "jquery": "^4.0.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "react": "^19.2.5",
    "wabt": "^1.0.39",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.3.9"
  }
}
