{
  "name": "@kitsunekode/kunai",
  "version": "0.1.2",
  "description": "Terminal-first media streaming CLI that resolves provider streams and launches mpv.",
  "keywords": [
    "anime",
    "bun",
    "cli",
    "mpv",
    "streaming",
    "terminal"
  ],
  "homepage": "https://github.com/kitsunekode/kunai#readme",
  "bugs": {
    "url": "https://github.com/kitsunekode/kunai/issues"
  },
  "license": "MIT",
  "author": "kitsunekode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kitsunekode/kunai.git"
  },
  "bin": {
    "kunai": "dist/kunai.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "module": "./dist/kunai.js",
  "exports": {
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "bun run src/main.ts",
    "start": "bun run src/main.ts",
    "test": "bun test test/unit test/integration",
    "test:unit": "bun test test/unit",
    "test:integration": "bun test test/integration",
    "test:live:allanime": "bun run test/live/allanime-demonslayer.smoke.ts",
    "test:live:miruro": "bun run test/live/miruro-demonslayer.smoke.ts",
    "test:live:providers": "bun run test:live:vidking && bun run test:live:rivestream && bun run test:live:allanime && bun run test:live:miruro",
    "test:live:rivestream": "bun run test/live/rivestream-breakingbad.smoke.ts",
    "test:live:vidking": "bun run test/live/vidking-bloodhounds.smoke.ts",
    "test:vhs:browse": "vhs test/vhs/browse-shell.tape",
    "test:vhs:help": "vhs test/vhs/help-overlay.tape",
    "test:vhs:launch": "vhs test/vhs/launch-story.tape",
    "typecheck": "bun tsc --noEmit",
    "lint": "oxlint .",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "check": "bun run typecheck && bun run lint && bun run fmt",
    "clean": "rm -rf dist",
    "build": "bun run scripts/build.ts",
    "build:prod": "bun run check && bun run build",
    "pkg:check": "bun run build && npm pack --dry-run --ignore-scripts",
    "release:dry-run": "bun run build:prod && bun run pkg:check",
    "link:global": "bun link",
    "unlink:global": "bun unlink",
    "relink:global": "bun run unlink:global && bun run link:global",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@types/react": "^19.2.14",
    "ink": "^7.0.2",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@kunai/core": "workspace:*",
    "@kunai/design": "workspace:*",
    "@kunai/providers": "workspace:*",
    "@kunai/storage": "workspace:*",
    "@kunai/types": "workspace:*",
    "@types/bun": "latest",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "optionalDependencies": {
    "discord-rpc": "^4.0.1"
  },
  "engines": {
    "bun": ">=1.3.9"
  }
}
